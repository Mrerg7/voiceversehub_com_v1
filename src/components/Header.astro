---
import { NAV_ITEMS, SITE_NAME, CONTACT_EMAIL } from '../utils/constants';
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-slate-950/90 backdrop-blur-lg border-b border-slate-800">
  <div class="max-w-screen-xl mx-auto px-8 py-5 flex items-center justify-between">
    <!-- Logo -->
    <div class="flex items-center gap-x-3">
      <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center">
        <i class="fa-solid fa-headset text-white text-xl"></i>
      </div>
      <span class="font-semibold text-xl tracking-tight">{SITE_NAME}</span>
    </div>

    <!-- Nav Links (desktop) -->
    <nav class="hidden md:flex items-center gap-x-6 text-sm text-slate-400">
      {NAV_ITEMS.map((item) => (
        <a href={item.href} class="hover:text-white transition">{item.label}</a>
      ))}
    </nav>

    <!-- CTA buttons -->
    <div class="flex items-center gap-x-4">
      <div class="hidden md:flex items-center gap-x-2 text-sm">
        <div class="premium-badge flex items-center gap-x-1.5">
          <i class="fa-solid fa-gem text-xs"></i>
          <span>PREMIUM ASSET</span>
        </div>
      </div>
      <a href={`mailto:${CONTACT_EMAIL}?subject=Inquiry%20for%20voiceversehub.com`}
         class="px-6 py-2.5 rounded-2xl bg-white text-slate-900 hover:bg-slate-100 transition-all font-semibold text-sm flex items-center gap-x-2 shadow-lg shadow-indigo-500/20">
        <span>Inquire Now</span>
        <i class="fa-solid fa-arrow-right text-xs"></i>
      </a>
    </div>
  </div>
</header>
